PORT=3000

# Network / security
# Interface to bind to. Defaults to 127.0.0.1 (localhost only). Set to 0.0.0.0
# only if you intentionally want the server reachable from other machines.
HOST=127.0.0.1
# Comma-separated list of origins allowed to call the API cross-origin.
# Leave empty to allow only same-origin requests (recommended).
ALLOWED_ORIGINS=
# Set when running behind a reverse proxy so req.ip (used by the rate limiter)
# resolves correctly. Use "true" to trust the immediate proxy, or a specific
# value supported by Express (e.g. "loopback", a hop count, or a subnet).
# Leave unset when not behind a proxy to avoid IP spoofing.
# TRUST_PROXY=true

# Default active provider (optional)
DEFAULT_PROVIDER_TYPE=openai
DEFAULT_PROVIDER_API_KEY=
DEFAULT_PROVIDER_MODEL=gpt-4o-mini

# Or Anthropic
# DEFAULT_PROVIDER_TYPE=anthropic
# DEFAULT_PROVIDER_API_KEY=sk-ant-...
# DEFAULT_PROVIDER_MODEL=claude-3-5-haiku-20241022

# Or Ollama (no API key needed)
# DEFAULT_PROVIDER_TYPE=ollama
# DEFAULT_PROVIDER_BASE_URL=http://localhost:11434
# DEFAULT_PROVIDER_MODEL=llama3.2

# Or any OpenAI-compatible endpoint
# DEFAULT_PROVIDER_TYPE=custom
# DEFAULT_PROVIDER_BASE_URL=https://api.groq.com/openai/v1
# DEFAULT_PROVIDER_API_KEY=gsk_...
# DEFAULT_PROVIDER_MODEL=llama-3.1-8b-instant
